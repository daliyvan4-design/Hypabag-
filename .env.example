# Copier vers .env.local et remplir. Ne jamais committer .env.local.

# --- Cloudinary -------------------------------------------------------------
# Laisser NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME vide pour servir les médias depuis
# public/assets/ sans passer par Cloudinary (utile en local).
# S'il est renseigné, les médias DOIVENT avoir été téléversés : pnpm media:upload
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Resend -----------------------------------------------------------------
# Sans clé, les formulaires répondent 503 et rien n'est envoyé.
RESEND_API_KEY=

# Expéditeur. Sans domaine vérifié chez Resend, utiliser exactement
# « onboarding@resend.dev » : Resend ne délivrera qu'à RESEND_SHOP_EMAIL.
RESEND_FROM=HYPA <onboarding@resend.dev>

# Destinataire des alertes « nouvelle commande » / « nouvel inscrit ».
RESEND_SHOP_EMAIL=

# --- Backoffice (/admin) ----------------------------------------------------
# Sans ces deux valeurs, le backoffice reste verrouillé (aucune connexion).
# ADMIN_SESSION_SECRET : chaîne aléatoire longue, ex. `openssl rand -base64 32`.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
